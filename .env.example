# Datenbank
DB_HOST=db
DB_NAME=owianzeiger
DB_USER=owianzeiger
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme-root

# App
# PRODUKTION: zwingend NODE_ENV=production! Sonst sind Dev-Endpoints
# (/dev/inbound-mail) offen und das Session-Cookie hat kein Secure-Flag.
NODE_ENV=development
# PRODUKTION: zwingend echtes Zufalls-Secret setzen (App verweigert sonst den
# Start). Erzeugen mit:  openssl rand -hex 32
SESSION_SECRET=change-this-to-a-random-64-char-string-before-going-live-!
# Öffentliche Basis-URL (Magic-Links, Mail-Links, Sitemap/Canonical).
# PRODUKTION: muss https://... sein (App verweigert sonst den Start).
APP_URL=http://localhost:3000

# App-Laufmodus: "watch" = Hot-Reload (Entwicklung). PRODUKTION: TSX_WATCH=
# (leer) setzen, sonst restartet jeder Deploy-rsync die App mehrfach.
# TSX_WATCH=
# Port-Bindings: PRODUKTION auf localhost begrenzen (Traffic läuft über Caddy):
# APP_BIND=127.0.0.1:3000
# MAILPIT_BIND=127.0.0.1:8025

# Produktion: auf "production" setzen, um den Caddy-Reverse-Proxy mit
# automatischem HTTPS (Let's Encrypt) zu starten. Leer lassen für lokale
# Entwicklung (dann läuft die App ungesichert auf Port 3000).
COMPOSE_PROFILES=
# Domain, für die Caddy ein Let's-Encrypt-Zertifikat ausstellt.
APP_DOMAIN=owia.treudler.net
# E-Mail für die ACME-/Let's-Encrypt-Registrierung.
ACME_EMAIL=admin@treudler.net

# Adresssuche (OpenStreetMap-Geocoder Photon, intern im Docker-Netz)
PHOTON_URL=http://photon:2322

# Karten-Kacheln (OSM-Raster-Tileserver, intern im Docker-Netz). Die App liefert
# die Kacheln same-origin über /tiles/... aus. Einmaliger Import nötig:
#   docker compose run --rm tileserver import
TILESERVER_URL=http://tileserver:80

# E-Mail
# MAIL_DRIVER=mailpit   -> Mailpit (dev, kein Auth)
# MAIL_DRIVER=smtp      -> Echter SMTP (prod)
# ACHTUNG: Es zählt exakt der String "smtp" – jeder andere Wert (auch "SMTP")
# fällt STILL auf Mailpit zurück und keine Mail erreicht echte Empfänger!
# MAIL_PORT: 587 (STARTTLS) verwenden; Port 465 (implizites TLS) wird nicht unterstützt.
MAIL_DRIVER=mailpit
MAIL_HOST=mail
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
# Absender = Antwort-Postfach: Antworten des Ordnungsamts an diese Adresse
# werden per IMAP (unten) abgeholt und dem Nutzer in der App angezeigt.
MAIL_FROM=owia@treudler.net
MAIL_FROM_NAME=OWiA-Anzeiger

# IMAP-Posteingang für Antworten des Ordnungsamts (gleiches Postfach wie MAIL_FROM).
# Werte leer lassen = Abruf deaktiviert (z.B. lokale Entwicklung; dort ersatzweise
# POST /dev/inbound-mail mit einer rohen RFC822-Mail).
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=owia@treudler.net
IMAP_PASS=
IMAP_POLL_SECONDS=120
# Absender-Domains, deren Mails per Aktenzeichen im Betreff einer Anzeige
# zugeordnet werden dürfen (Spoofing-Schutz; Antworten auf unsere Mails
# matchen unabhängig davon über die Message-ID-Kette).
REPLY_TRUSTED_DOMAINS=stadt-frankfurt.de

# Empfänger-Adresse je Stadt: MAIL_TO_<CITYID> (CITYID wie in src/config/cities.ts).
# Überschreibt den dort hinterlegten Default. Für weitere Städte analog ergänzen.
MAIL_TO_FRANKFURT=ordnungsamt@stadt-frankfurt.de

# Admins (kommagetrennte E-Mail-Adressen): sehen /admin/anzeigen und geben
# eingereichte Anzeigen frei (Versand ans Ordnungsamt) oder lehnen sie ab.
ADMIN_EMAILS=