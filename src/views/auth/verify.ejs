<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h2 class="card-title mb-3">Code eingeben</h2>
        <p class="text-muted small mb-4">
          Wir haben einen 6-stelligen Code an <strong><%= email %></strong> gesendet.
          Gib ihn hier ein oder klick auf den Link in der E-Mail.
        </p>

        <% if (locals.error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form method="post" action="/login/verify">
          <input type="hidden" name="email" value="<%= email %>">
          <div class="mb-3">
            <label class="form-label">Anmeldecode</label>
            <input type="text" name="code" class="form-control form-control-lg text-center"
                   inputmode="numeric" pattern="[0-9]*" maxlength="6"
                   autocomplete="one-time-code" required autofocus
                   style="letter-spacing:.4em;">
          </div>
          <button type="submit" class="btn btn-primary w-100">Anmelden</button>
        </form>

        <hr>
        <p class="text-center mb-0 small">
          Keinen Code erhalten? <a href="/login">Erneut anfordern</a>
        </p>
      </div>
    </div>
  </div>
</div>
