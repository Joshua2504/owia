<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-0">Meine Anzeigen</h2>
  <div class="d-flex gap-2">
    <a class="btn btn-outline-primary" href="/import">📸 Foto-Import</a>
    <form method="post" action="/anzeige/neu" class="m-0">
      <button type="submit" class="btn btn-primary">+ Neue Anzeige</button>
    </form>
  </div>
</div>

<!-- Anonyme Übersichtskarte aller versendeter Anzeigen (gleiche Daten wie die Startseite). -->
<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h5 class="card-title mb-1">Übersicht</h5>
    <p class="text-muted small mb-3">
      Alle versendeter Anzeigen – anonymisiert, Fotos stark verpixelt.
      <span class="text-warning-emphasis">Deine eigenen Entwürfe sind orange markiert.</span>
    </p>
    <div id="overview-map" class="rounded border" style="height:380px" data-include-own="1"></div>
  </div>
</div>

<% if (reports.length === 0) { %>
  <div class="card shadow-sm">
    <div class="card-body text-center py-5 text-muted">
      <p class="mb-3">Noch keine Anzeigen vorhanden.</p>
      <form method="post" action="/anzeige/neu" class="m-0">
        <button type="submit" class="btn btn-primary">Erste Anzeige erstatten</button>
      </form>
    </div>
  </div>
<% } else { %>
  <div class="card shadow-sm">
    <%- include('../partials/report-table', { reports, imagesByReport, queueId: null }) %>
  </div>
<% } %>

<link rel="stylesheet" href="/public/vendor/leaflet.css">
<script src="/public/vendor/leaflet.js"></script>
<script src="/public/js/overview-map.js"></script>
<script src="/public/js/report-table.js"></script>
<script src="/public/js/image-loupe.js"></script>
