<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-0">Meine Anzeigen</h2>
  <form method="post" action="/report/new" class="m-0">
    <button type="submit" class="btn btn-primary">+ Neue Anzeige</button>
  </form>
</div>

<!-- Anonyme Übersichtskarte aller versendeter Anzeigen (gleiche Daten wie die Startseite). -->
<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h5 class="card-title mb-1">Öffentliche Übersicht</h5>
    <p class="text-muted small mb-3">
      Alle versendeter Anzeigen – anonymisiert, Fotos stark verpixelt.
    </p>
    <div id="overview-map" class="rounded border" style="height:380px"></div>
  </div>
</div>

<% if (reports.length === 0) { %>
  <div class="card shadow-sm">
    <div class="card-body text-center py-5 text-muted">
      <p class="mb-3">Noch keine Anzeigen vorhanden.</p>
      <form method="post" action="/report/new" class="m-0">
        <button type="submit" class="btn btn-primary">Erste Anzeige erstatten</button>
      </form>
    </div>
  </div>
<% } else { %>
  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Aktenzeichen</th>
            <th>Kennzeichen</th>
            <th>Tattag</th>
            <th>Tatort</th>
            <th>Verstoß</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% for (const r of reports) { %>
            <tr>
              <td class="text-nowrap"><code class="small"><%= r.aktenzeichen || '—' %></code></td>
              <td><code><%= r.kennzeichen %></code></td>
              <td class="text-nowrap">
                <%= r.tattag ? new Date(r.tattag).toLocaleDateString('de-DE') : '—' %>
                <% if (r.tatzeit_von) { %>
                  <span class="text-muted"><%= String(r.tatzeit_von).slice(0,5) %></span>
                <% } %>
              </td>
              <td class="text-truncate" style="max-width:180px"><%= r.tatort %></td>
              <td class="text-truncate" style="max-width:180px"><%= r.verstoss_art %></td>
              <td>
                <% if (r.status === 'versendet') { %>
                  <span class="badge bg-success">Versendet</span>
                <% } else if (r.status === 'entwurf') { %>
                  <span class="badge bg-secondary">Entwurf</span>
                <% } else { %>
                  <span class="badge bg-info">Eingereicht</span>
                <% } %>
              </td>
              <td>
                <% if (r.status === 'entwurf') { %>
                  <a href="/report/<%= r.id %>/edit" class="btn btn-sm btn-outline-primary">Bearbeiten</a>
                <% } else { %>
                  <a href="/report/<%= r.id %>" class="btn btn-sm btn-outline-secondary">Details</a>
                <% } %>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css">
<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/public/js/overview-map.js"></script>
