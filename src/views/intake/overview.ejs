<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-0">Foto-Import – Ergebnis</h2>
  <a class="btn btn-outline-secondary btn-sm" href="/import">← Neuer Import</a>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
      <div>
        <h5 class="card-title mb-1"><%= drafts.length %> Entwürfe erstellt</h5>
        <p class="text-muted small mb-0">
          Fotos wurden nach Standort und Aufnahmezeit gruppiert – bitte jeden Entwurf
          prüfen und die Verstoßart wählen.
        </p>
      </div>
      <% if (firstOpenAz) { %>
        <a class="btn btn-primary" href="/anzeige/<%= firstOpenAz %>/bearbeiten?queue=<%= batch.id %>">
          Prüfen starten (<%= openCount %> offen)
        </a>
      <% } %>
    </div>
  </div>
</div>

<% if (drafts.length) { %>
  <div class="card shadow-sm mb-4">
    <%- include('../partials/report-table', { reports: drafts, imagesByReport, queueId: batch.id }) %>
  </div>
<% } %>

<% if (unassigned.length) { %>
  <div class="card shadow-sm">
    <div class="card-body">
      <h5 class="card-title mb-1">Nicht zugeordnete Fotos (<%= unassigned.length %>)</h5>
      <p class="text-muted small mb-3">
        Diese Fotos enthalten weder GPS-Position noch Aufnahmezeit (z.&nbsp;B. Screenshots) –
        bitte manuell einem Entwurf zuordnen oder einen neuen Entwurf daraus erstellen.
      </p>
      <div class="row g-3">
        <% for (const p of unassigned) { %>
          <div class="col-6 col-md-4 col-lg-3" data-photo-card="<%= p.id %>">
            <div class="card h-100">
              <img src="/import/<%= batch.id %>/photo/<%= p.id %>/thumb.jpg" alt=""
                   class="card-img-top" style="height:120px;object-fit:cover;cursor:zoom-in"
                   loading="lazy" decoding="async"
                   data-full-src="/import/<%= batch.id %>/photo/<%= p.id %>" title="Klick: vergrößern">
              <div class="card-body p-2">
                <select class="form-select form-select-sm mb-2" data-assign-select="<%= p.id %>">
                  <option value="">Entwurf wählen …</option>
                  <% for (const d of drafts) { %>
                    <% if (d.status === 'entwurf') { %>
                      <option value="<%= d.aktenzeichen %>">
                        <%= d.tattag_fmt || d.aktenzeichen %><% if (d.tatort) { %> – <%= d.tatort.slice(0, 30) %><% } %>
                      </option>
                    <% } %>
                  <% } %>
                </select>
                <div class="d-flex gap-1">
                  <button type="button" class="btn btn-sm btn-outline-primary flex-fill"
                          data-assign-btn="<%= p.id %>">Zuordnen</button>
                  <button type="button" class="btn btn-sm btn-outline-secondary flex-fill"
                          data-newdraft-btn="<%= p.id %>">Neuer Entwurf</button>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    (function () {
      var batchId = <%= batch.id %>
      function assign(photoId, body) {
        fetch('/import/' + batchId + '/photos/' + photoId + '/assign', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d } }) })
          .then(function (res) {
            if (!res.ok) { alert(res.d.error || 'Zuordnung fehlgeschlagen.'); return }
            location.reload()
          })
          .catch(function () { alert('Zuordnung fehlgeschlagen.') })
      }
      document.querySelectorAll('[data-assign-btn]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var id = btn.getAttribute('data-assign-btn')
          var sel = document.querySelector('[data-assign-select="' + id + '"]')
          if (!sel || !sel.value) { alert('Bitte zuerst einen Entwurf wählen.'); return }
          assign(id, { az: sel.value })
        })
      })
      document.querySelectorAll('[data-newdraft-btn]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          assign(btn.getAttribute('data-newdraft-btn'), { newDraft: true })
        })
      })
    })()
  </script>
<% } %>

<script src="/public/js/report-table.js"></script>
