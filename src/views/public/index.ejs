<div class="row justify-content-center">
  <div class="col-lg-10">
    <!-- Prominenter Call-to-Action ganz oben -->
    <div class="text-center py-5">
      <h1 class="display-5 fw-bold mb-3">Falschparker melden – kostenlos Anzeige erstatten</h1>
      <p class="lead text-muted mb-4 mx-auto" style="max-width:640px">
        Gehweg, Radweg oder Feuerwehrzufahrt zugeparkt? Erstatte in wenigen Minuten
        Anzeige wegen einer Park-Ordnungswidrigkeit – mit Beweisfotos, automatischem
        Tatort aus den Bildern und fertigem PDF fürs zuständige Ordnungsamt. Kostenlos.
        Wir schalten Stadt für Stadt frei – ist deine noch nicht dabei, trag dich für
        die Info ein.
      </p>
      <% if (currentUser) { %>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
          <form method="post" action="/anzeige/neu" class="m-0">
            <button type="submit" class="btn btn-primary btn-lg px-4">+ Neue Anzeige erstatten</button>
          </form>
          <a href="/anzeigen" class="btn btn-outline-secondary btn-lg px-4">Meine Anzeigen</a>
        </div>
      <% } else { %>
        <a href="/login" class="btn btn-primary btn-lg px-5 py-3 fw-semibold shadow-sm">
          Anmelden &amp; Anzeige erstatten
        </a>
      <% } %>
    </div>

    <!-- Öffentliche Kennzahlen (aggregiert, anonym) -->
    <% const stats = locals.stats || {} %>
    <div class="row g-3 mb-4 text-center">
      <div class="col-6 col-md-3">
        <div class="card shadow-sm h-100"><div class="card-body">
          <div class="display-6 fw-bold"><%= stats.total || 0 %></div>
          <div class="text-muted small">Anzeigen versendet</div>
        </div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card shadow-sm h-100"><div class="card-body">
          <div class="display-6 fw-bold"><%= stats.last30 || 0 %></div>
          <div class="text-muted small">in den letzten 30 Tagen</div>
        </div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card shadow-sm h-100"><div class="card-body">
          <div class="display-6 fw-bold"><%= stats.fotos || 0 %></div>
          <div class="text-muted small">Beweisfotos eingereicht</div>
        </div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card shadow-sm h-100"><div class="card-body">
          <div class="fw-bold mt-2" style="font-size:1.05rem"><%= stats.topVerstoss || '–' %></div>
          <div class="text-muted small">häufigster Verstoß</div>
        </div></div>
      </div>
    </div>

    <!-- So funktioniert's: erklärt den Ablauf (und liefert Suchmaschinen Kontext) -->
    <section class="mb-5">
      <h2 class="h4 mb-3 text-center">So meldest du einen Falschparker</h2>
      <div class="row g-3">
        <div class="col-md-4">
          <div class="card h-100 shadow-sm"><div class="card-body">
            <div class="fs-3 mb-1">📸</div>
            <h3 class="h6">1. Fotos aufnehmen &amp; hochladen</h3>
            <p class="small text-muted mb-0">
              Beweisfotos vom falsch geparkten Fahrzeug machen (Kennzeichen und Situation
              sichtbar). Beim Foto-Import werden Standort und Uhrzeit automatisch aus den
              Bildern übernommen – auch für viele Fotos auf einmal.
            </p>
          </div></div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm"><div class="card-body">
            <div class="fs-3 mb-1">📝</div>
            <h3 class="h6">2. Verstoß auswählen</h3>
            <p class="small text-muted mb-0">
              Parken auf dem Gehweg, Radweg, in der Feuerwehrzufahrt oder im Halteverbot –
              Verstoßart wählen, Angaben prüfen, fertig. Ein amtliches PDF-Formular wird
              automatisch erzeugt.
            </p>
          </div></div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm"><div class="card-body">
            <div class="fs-3 mb-1">📮</div>
            <h3 class="h6">3. Wir prüfen &amp; verschicken</h3>
            <p class="small text-muted mb-0">
              Nach dem Einreichen prüfen wir die Anzeige und senden sie ans zuständige
              Ordnungsamt – du bekommst die E-Mail in Kopie und siehst Antworten des Amts
              direkt in der App.
            </p>
          </div></div>
        </div>
      </div>
    </section>

    <!-- Unterstützte Städte + Newsletter-Anmeldung für neue Städte/PLZ -->
    <section class="mb-5" id="newsletter">
      <h2 class="h4 mb-3 text-center">Unterstützte Städte</h2>
      <div class="row g-3 justify-content-center">
        <% (locals.cities || []).forEach((city) => { %>
          <div class="col-md-4">
            <div class="card h-100 shadow-sm"><div class="card-body">
              <h3 class="h6 mb-1">📍 <%= city.name %></h3>
              <p class="small text-muted mb-0">
                Anzeigen gehen an: <%= city.ordnungsamt %>
              </p>
            </div></div>
          </div>
        <% }) %>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm border-primary-subtle"><div class="card-body">
            <h3 class="h6 mb-1">✉️ Deine Stadt fehlt?</h3>
            <p class="small text-muted mb-2">
              Wir schalten laufend neue Städte und Postleitzahlgebiete frei. Trag dich
              ein und wir benachrichtigen dich, sobald es bei dir losgeht.
            </p>
            <form method="post" action="/newsletter" class="d-flex flex-column gap-2">
              <input type="email" name="email" class="form-control form-control-sm"
                     placeholder="deine@email.de" required autocomplete="email"
                     aria-label="E-Mail-Adresse für Benachrichtigungen">
              <div class="d-flex gap-2">
                <input type="text" name="plz" class="form-control form-control-sm"
                       placeholder="PLZ (optional)" inputmode="numeric" pattern="[0-9]{5}"
                       maxlength="5" autocomplete="postal-code" style="max-width:9rem"
                       aria-label="Postleitzahl (optional)"
                       title="5-stellige Postleitzahl">
                <button type="submit" class="btn btn-primary btn-sm text-nowrap flex-grow-1">Eintragen</button>
              </div>
            </form>
            <p class="form-text small mt-2 mb-0">
              Die PLZ hilft uns zu entscheiden, wo es als Nächstes losgeht. Mit Klick auf
              „Eintragen" bekommst du eine Bestätigungs-Mail (Double-Opt-In). Abmeldung
              jederzeit über den Link in jeder E-Mail.
            </p>
          </div></div>
        </div>
      </div>
    </section>

    <!-- Karte darunter -->
    <h2 class="h5 mb-1">Öffentliche Übersicht</h2>
    <p class="text-muted small mb-3">
      Anonymisierte Karte aller versendeter Anzeigen – keine personenbezogenen Daten,
      Fotos stark verpixelt.
    </p>
    <!-- Übersichtskarte: lädt Marker aus /api/public/reports, Kacheln aus /tiles/... -->
    <div id="overview-map" class="rounded border shadow-sm"
         style="height:520px"
         data-center-lat="<%= centerLat %>" data-center-lon="<%= centerLon %>"></div>

    <!-- FAQ: beantwortet die häufigsten Suchanfragen (auch als FAQPage-Schema unten) -->
    <%
    const faq = [
      ['Darf ich Falschparker überhaupt anzeigen?',
       'Ja. Jeder darf eine Ordnungswidrigkeit wie Falschparken beim Ordnungsamt anzeigen (Privatanzeige nach § 46 OWiG i.V.m. der StVO). Wichtig sind Beweisfotos, Tatort, Datum, Uhrzeit und das Kennzeichen – genau das erfasst OWiA-Anzeiger für dich.'],
      ['Was kostet die Anzeige eines Falschparkers?',
       'Nichts. OWiA-Anzeiger ist kostenlos. Auch beim Ordnungsamt entstehen dir als anzeigender Person keine Kosten.'],
      ['Welche Parkverstöße kann ich melden?',
       'Unter anderem: Parken auf dem Gehweg oder Radweg, im absoluten oder eingeschränkten Halteverbot, in zweiter Reihe, in Feuerwehrzufahrten, auf Behindertenparkplätzen, vor abgesenkten Bordsteinen, an Kreuzungen und auf der linken Fahrbahnseite.'],
      ['Welche Fotos brauche ich als Beweis?',
       'Am besten mehrere Fotos: eine Übersicht der Situation (z.B. blockierter Gehweg samt Umgebung) und eine Nahaufnahme mit lesbarem Kennzeichen. Fotografierst du denselben Verstoß über einen längeren Zeitraum mehrfach, belegt das die Dauer.'],
      ['Bleibe ich anonym?',
       'Gegenüber der Öffentlichkeit ja – die öffentliche Karte zeigt keine personenbezogenen Daten. Gegenüber dem Ordnungsamt nicht: Anonyme Anzeigen werden nicht bearbeitet, als Zeugin oder Zeuge musst du mit Name und Anschrift benannt sein.'],
      ['Was passiert nach dem Absenden?',
       'Wir prüfen deine Anzeige und senden sie mit allen Angaben und Beweisfotos per E-Mail an das zuständige Ordnungsamt – du erhältst eine Kopie. Antworten des Amts (z.B. Rückfragen oder der Ausgang des Verfahrens) siehst du direkt in der App.'],
    ]
    %>
    <section class="my-5">
      <h2 class="h4 mb-3 text-center">Häufige Fragen zum Melden von Falschparkern</h2>
      <div class="accordion" id="faq">
        <% faq.forEach(([q, a], i) => { %>
          <div class="accordion-item">
            <h3 class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                      data-bs-target="#faq-<%= i %>"><%= q %></button>
            </h3>
            <div id="faq-<%= i %>" class="accordion-collapse collapse" data-bs-parent="#faq">
              <div class="accordion-body small"><%= a %></div>
            </div>
          </div>
        <% }) %>
      </div>
    </section>

    <!-- Strukturierte Daten für Suchmaschinen (FAQ + Web-Anwendung) -->
    <script type="application/ld+json"><%- JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'WebApplication',
          name: 'OWiA-Anzeiger',
          url: (locals.appUrl || '') + '/',
          description: locals.metaDescription || '',
          applicationCategory: 'UtilityApplication',
          operatingSystem: 'Web',
          offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
          areaServed: (locals.cities || []).map((c) => ({ '@type': 'City', name: c.name })),
          inLanguage: 'de',
        },
        {
          '@type': 'FAQPage',
          mainEntity: faq.map(([q, a]) => ({
            '@type': 'Question',
            name: q,
            acceptedAnswer: { '@type': 'Answer', text: a },
          })),
        },
      ],
    }).replace(/</g, '\\u003c') %></script>
  </div>
</div>

<link rel="stylesheet" href="/public/vendor/leaflet.css">
<script src="/public/vendor/leaflet.js"></script>
<script src="/public/js/overview-map.js"></script>
