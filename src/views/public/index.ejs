<div class="row justify-content-center">
  <div class="col-lg-10">
    <div class="text-center mb-4">
      <h1 class="h3 mb-2">Falschparken in Frankfurt – öffentliche Übersicht</h1>
      <p class="text-muted mb-0">
        Anonymisierte Karte aller versendeter Anzeigen. Es werden keine personenbezogenen
        Daten angezeigt – Kennzeichen und Personen sind nicht erkennbar, Fotos stark verpixelt.
      </p>
    </div>

    <!-- Übersichtskarte: lädt Marker aus /api/public/reports, Kacheln aus /tiles/... -->
    <div id="overview-map" class="rounded border shadow-sm"
         style="height:520px"
         data-center-lat="<%= centerLat %>" data-center-lon="<%= centerLon %>"></div>

    <div class="d-flex justify-content-center gap-2 mt-4">
      <% if (currentUser) { %>
        <a href="/dashboard" class="btn btn-outline-secondary">Meine Anzeigen</a>
        <form method="post" action="/report/new" class="m-0">
          <button type="submit" class="btn btn-primary">+ Neue Anzeige</button>
        </form>
      <% } else { %>
        <a href="/login" class="btn btn-primary">Anmelden &amp; Anzeige erstatten</a>
      <% } %>
    </div>
  </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css">
<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/public/js/overview-map.js"></script>
