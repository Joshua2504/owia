<div class="row justify-content-center">
  <div class="col-lg-7">
    <h2 class="mb-4">Einstellungen</h2>

    <div class="card shadow-sm mb-4">
      <div class="card-header">Persönliche Daten</div>
      <div class="card-body p-4">
        <p class="text-muted small mb-3">
          Diese Daten werden automatisch in das amtliche Anzeige-Formular eingetragen.
        </p>
        <form method="post" action="/einstellungen">
          <div class="row g-3">
            <div class="col-sm-6">
              <label class="form-label">Vorname</label>
              <input type="text" name="vorname" class="form-control"
                     value="<%= user.vorname || '' %>">
            </div>
            <div class="col-sm-6">
              <label class="form-label">Nachname</label>
              <input type="text" name="nachname" class="form-control"
                     value="<%= user.nachname || '' %>">
            </div>
            <div class="col-sm-8">
              <label class="form-label">Straße und Hausnummer</label>
              <input type="text" name="strasse" class="form-control"
                     value="<%= user.strasse || '' %>"
                     data-address-autocomplete data-fill="street"
                     data-target-plz="#plz" data-target-ort="#ort"
                     placeholder="Adresse suchen – PLZ und Ort werden ergänzt">
            </div>
            <div class="col-sm-4">
              <label class="form-label">PLZ</label>
              <input type="text" name="plz" id="plz" class="form-control" maxlength="10"
                     value="<%= user.plz || '' %>">
            </div>
            <div class="col-sm-6">
              <label class="form-label">Ort</label>
              <input type="text" name="ort" id="ort" class="form-control"
                     value="<%= user.ort || '' %>">
            </div>
            <div class="col-sm-6">
              <label class="form-label">Telefon</label>
              <input type="tel" name="telefon" class="form-control"
                     value="<%= user.telefon || '' %>">
            </div>
            <div class="col-sm-12">
              <label class="form-label">E-Mail</label>
              <input type="email" class="form-control" value="<%= user.email %>" disabled>
              <div class="form-text">Änderbar weiter unten – mit Bestätigung an die neue Adresse.</div>
            </div>
          </div>

          <button type="submit" class="btn btn-primary mt-4">Speichern</button>
        </form>
      </div>
    </div>

    <!-- E-Mail-Adresse ändern (Bestätigung an die neue Adresse) -->
    <div class="card shadow-sm mt-4">
      <div class="card-body">
        <h5 class="card-title mb-1">E-Mail-Adresse ändern</h5>
        <p class="small text-muted">
          Die Anmeldung läuft über deine E-Mail-Adresse. Nach dem Absenden erhältst du
          an die <strong>neue</strong> Adresse einen Bestätigungslink (1 Stunde gültig) –
          erst mit dem Klick darauf wird die Adresse umgestellt.
        </p>
        <form method="post" action="/einstellungen/email" class="d-flex gap-2 flex-wrap">
          <input type="email" name="email_neu" class="form-control w-auto" style="min-width:280px"
                 placeholder="neue@adresse.de" required>
          <button type="submit" class="btn btn-outline-primary">Bestätigungslink senden</button>
        </form>
      </div>
    </div>

    <!-- DSGVO: Auskunft/Datenübertragbarkeit -->
    <div class="card shadow-sm mt-4">
      <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <h5 class="card-title mb-1">Datenexport (DSGVO)</h5>
          <p class="small text-muted mb-0">
            Lade alle zu deinem Konto gespeicherten Daten als ZIP herunter –
            Profil und Anzeigen als JSON plus sämtliche Dateien: Beweisfotos
            (inkl. Originale), PDFs, Nachrichtenverlauf mit Anhängen und
            Import-Fotos (Art. 15/20 DSGVO).
          </p>
        </div>
        <a href="/einstellungen/export" class="btn btn-outline-primary">⬇ Daten exportieren</a>
      </div>
    </div>

    <!-- DSGVO Art. 17: Konto schließen & personenbezogene Daten anonymisieren -->
    <div class="card shadow-sm mt-4 border-danger">
      <div class="card-body">
        <h5 class="card-title mb-1">Konto schließen</h5>
        <p class="small text-muted mb-1">
          Entfernt <strong>unwiderruflich</strong> deine personenbezogenen Daten –
          Profil (Name, Anschrift, Telefon), E-Mail-Adresse, die erzeugten PDFs und
          den Nachrichtenverlauf mit dem Ordnungsamt. Deine Anmeldung wird deaktiviert.
        </p>
        <p class="small text-muted">
          Deine bereits erstellten Anzeigen bleiben <strong>anonymisiert</strong>
          erhalten (ohne deinen Namen, aber inkl. Fotos und Tatort) – zu
          Dokumentations- und Statistikzwecken und für die öffentliche Übersichtskarte.
          Tipp: vorher die Daten exportieren.
        </p>
        <form method="post" action="/einstellungen/loeschen" class="d-flex gap-2 flex-wrap"
              onsubmit="return confirm('Konto schließen? Deine personenbezogenen Daten werden unwiderruflich entfernt.')">
          <input type="text" name="bestaetigung" class="form-control w-auto"
                 placeholder="Zur Bestätigung: LÖSCHEN" required autocomplete="off">
          <button type="submit" class="btn btn-outline-danger">Konto schließen &amp; anonymisieren</button>
        </form>
      </div>
    </div>
  </div>
</div>
