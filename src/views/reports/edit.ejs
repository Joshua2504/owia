<%
const r = locals.report || {}
const images = locals.images || []
const pad = (n) => String(n).padStart(2, '0')
const toDateInput = (d) => {
  if (!d) return ''
  const dt = new Date(d)
  return isNaN(dt) ? '' : `${dt.getFullYear()}-${pad(dt.getMonth() + 1)}-${pad(dt.getDate())}`
}
const hhmm = (t) => (t ? String(t).slice(0, 5) : '')
const now = new Date()
const today = toDateInput(now)
const nowTime = `${pad(now.getHours())}:${pad(now.getMinutes())}`
%>

<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="mb-0">Anzeige bearbeiten</h2>
      <% if (locals.queue) { %>
        <a href="/intake/<%= queue.batchId %>" class="btn btn-outline-secondary btn-sm">← Import-Übersicht</a>
      <% } else { %>
        <a href="/dashboard" class="btn btn-outline-secondary btn-sm">← Übersicht</a>
      <% } %>
    </div>

    <% if (locals.queue) { %>
      <div class="card shadow-sm mb-3 sticky-top" style="top:.5rem;z-index:1030">
        <div class="card-body py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
          <div class="fw-semibold">Entwurf <%= queue.position %> von <%= queue.total %></div>
          <div class="d-flex gap-2">
            <% if (queue.prevAz) { %>
              <a class="btn btn-sm btn-outline-secondary" href="/report/<%= queue.prevAz %>/edit?queue=<%= queue.batchId %>">← Zurück</a>
            <% } %>
            <% if (queue.nextAz) { %>
              <a class="btn btn-sm btn-outline-secondary" href="/report/<%= queue.nextAz %>/edit?queue=<%= queue.batchId %>">Überspringen →</a>
            <% } %>
            <button type="submit" form="report-form" class="btn btn-sm btn-primary">
              Speichern &amp; weiter<% if (!queue.nextAz) { %> (letzter)<% } %>
            </button>
          </div>
        </div>
      </div>
    <% } %>

    <% if (locals.error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="card shadow-sm">
      <div class="card-body p-4">
        <form id="report-form" method="post" action="/report/<%= r.aktenzeichen %>/save"
              data-report-id="<%= r.aktenzeichen %>"
              data-ai-enabled="<%= (typeof aiEnabled !== 'undefined' && aiEnabled) ? '1' : '0' %>">
          <% if (locals.queue) { %>
            <input type="hidden" name="queue" value="<%= queue.batchId %>">
          <% } %>

          <h5 class="mb-3">Beweisfotos</h5>
          <div class="mb-4">
            <label class="form-label">Bilder hinzufügen</label>
            <input type="file" id="bilder-input" class="form-control"
                   accept="image/png,image/jpeg,image/heic,image/heif,.heic,.heif" multiple>
            <div class="form-text">
              Bereiche (z.&nbsp;B. Personen) kannst du schwärzen – wird automatisch gespeichert.
            </div>
            <div class="form-text">
              <strong>🤖 Automatisch ausfüllen</strong>: Kennzeichen &amp; Verstoßart per KI –
              0,10 €/Bild oder <a href="/konto">Flatrate</a>.
            </div>
            <% if (typeof subscriptionActive !== 'undefined' && subscriptionActive) { %>
              <div class="form-text text-success">✓ Flatrate aktiv.</div>
            <% } else if (typeof aiEnabled !== 'undefined' && !aiEnabled) { %>
              <div class="form-text text-danger">
                Kein Guthaben – bitte <a href="/konto">aufladen</a> oder Flatrate buchen.
              </div>
            <% } %>
            <!-- Bereits gespeicherte Bilder; das Script lädt sie als bearbeitbare Karten. -->
            <script id="existing-images-data" type="application/json"><%- JSON.stringify(images.map((img) => ({ id: img.id, url: `/report/${r.aktenzeichen}/image/${img.id}`, status: img.analysis_status }))) %></script>
            <div id="image-editor" class="row g-3 mt-1"></div>
          </div>

          <h5 class="mb-3">Fahrzeug</h5>
          <!-- Status/Hinweis der automatischen Foto-Analyse (Kennzeichen + Verstoßart). -->
          <div id="ai-status" class="form-text mb-2" role="status"></div>
          <div class="row g-3 mb-4">
            <div class="col-sm-6">
              <label class="form-label">Kennzeichen <span class="text-danger">*</span></label>
              <input type="text" name="kennzeichen" class="form-control text-uppercase"
                     value="<%= r.kennzeichen || '' %>"
                     placeholder="z.B. F-AB 1234">
            </div>
            <div class="col-sm-6">
              <label class="form-label">Fahrzeugmarke / -farbe</label>
              <input type="text" name="fahrzeug_marke" class="form-control"
                     value="<%= r.fahrzeug_marke || '' %>"
                     placeholder="z.B. VW Golf, grau">
            </div>
          </div>

          <h5 class="mb-3">Tat</h5>
          <div class="row g-3 mb-4">
            <div class="col-sm-4">
              <label class="form-label">Tattag <span class="text-danger">*</span></label>
              <input type="date" name="tattag" class="form-control"
                     value="<%= toDateInput(r.tattag) || today %>">
            </div>
            <div class="col-sm-4">
              <label class="form-label">Uhrzeit von <span class="text-danger">*</span></label>
              <input type="time" name="tatzeit_von" class="form-control"
                     value="<%= hhmm(r.tatzeit_von) || nowTime %>">
            </div>
            <div class="col-sm-4">
              <label class="form-label">Uhrzeit bis</label>
              <input type="time" name="tatzeit_bis" class="form-control"
                     value="<%= hhmm(r.tatzeit_bis) %>">
            </div>
            <!-- Uhrzeit (von = frühestes, bis = spätestes Foto) aus den EXIF-Daten der
                 hochgeladenen Fotos übernehmen. Erscheint nur, wenn mindestens ein Foto
                 eine Aufnahmezeit enthält (Befüllung in public/js/report-form.js). -->
            <div class="col-sm-12 d-none mt-0" id="photo-time-row">
              <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-photo-times">
                🕒 Uhrzeit aus Fotos übernehmen
              </button>
              <span id="photo-time-status" class="form-text ms-2"></span>
            </div>
            <div class="col-sm-12">
              <label class="form-label">Tatort <span class="text-danger">*</span></label>
              <input type="text" name="tatort" id="tatort" class="form-control"
                     value="<%= r.tatort || '' %>"
                     data-address-autocomplete data-fill="full"
                     data-geo-scope="<%= locals.city ? city.geo.scope : 'ffm' %>"
                     placeholder="Adresse in <%= locals.city ? city.name : 'Frankfurt' %> eingeben und aus der Liste wählen …">
              <div class="d-flex align-items-center flex-wrap gap-2 mt-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-current-location">
                  📍 Aktuellen Standort verwenden
                </button>
                <span id="geo-status" class="form-text m-0"></span>
              </div>
              <div class="form-text">
                Adresse tippen und einen Vorschlag wählen, den aktuellen Standort verwenden
                oder Standort und Uhrzeit aus einem oben hochgeladenen Foto übernehmen.
              </div>
              <% if (locals.city) { %>
                <!-- Zuständige Behörde direkt beim Tatort, da sie sich aus dem Ort ergibt. -->
                <div class="form-text d-flex align-items-start gap-2 mt-2 mb-0" role="status">
                  <span aria-hidden="true">🏛️</span>
                  <div>
                    Diese Anzeige geht an das <strong><%= city.ordnungsamt %></strong>
                    (<%= city.email %>).
                  </div>
                </div>
              <% } %>
              <!-- Karte zum Tatort. Marker lässt sich verschieben; die Adresse wird dann
                   per Reverse-Geocoding aktualisiert. Koordinaten gehen in die Hidden-Felder. -->
              <div id="tatort-map" class="rounded border mt-2"
                   style="height:320px"
                   data-lat="<%= r.tatort_lat || '' %>" data-lon="<%= r.tatort_lon || '' %>"
                   data-thumb="<%= (typeof firstImageUrl !== 'undefined' && firstImageUrl) ? firstImageUrl : '' %>"
                   data-center-lat="<%= city.geo.mapLat %>" data-center-lon="<%= city.geo.mapLon %>"></div>
              <div class="form-text">
                Den Marker kannst du zur genauen Stelle ziehen – die Adresse wird dann übernommen.
              </div>
              <input type="hidden" name="tatort_lat" value="<%= r.tatort_lat || '' %>">
              <input type="hidden" name="tatort_lon" value="<%= r.tatort_lon || '' %>">
            </div>
            <div class="col-sm-12">
              <label class="form-label">Verstoßart <span class="text-danger">*</span></label>
              <select name="verstoss_art" class="form-select">
                <option value="">– bitte wählen –</option>
                <% for (const art of verstossArten) { %>
                  <option value="<%= art %>" <%= r.verstoss_art === art ? 'selected' : '' %>><%= art %></option>
                <% } %>
              </select>
            </div>
            <div class="col-sm-12">
              <label class="form-label">Beschreibung</label>
              <textarea name="beschreibung" class="form-control" rows="3"
                        placeholder="Optionale Schilderung des Vorfalls"><%= r.beschreibung || '' %></textarea>
            </div>
            <div class="col-sm-12">
              <div class="form-check">
                <input type="checkbox" class="form-check-input" name="fahrzeug_verlassen"
                       id="fahrzeug-verlassen" value="1" <%= r.fahrzeug_verlassen === 1 ? 'checked' : '' %>>
                <label class="form-check-label" for="fahrzeug-verlassen">Das Fahrzeug war verlassen</label>
              </div>
              <div class="form-text">Wird dem Tatvorwurf als Satz „Das Fahrzeug war verlassen." hinzugefügt.</div>
            </div>
            <div class="col-sm-12">
              <label class="form-label d-block">Wurde jemand behindert?</label>
              <div class="btn-group" role="group" aria-label="Wurde jemand behindert?">
                <input type="radio" class="btn-check" name="behinderung" id="behinderung-ja"
                       value="ja" <%= r.behinderung === 1 ? 'checked' : '' %>>
                <label class="btn btn-outline-secondary" for="behinderung-ja">Ja</label>
                <input type="radio" class="btn-check" name="behinderung" id="behinderung-nein"
                       value="nein" <%= r.behinderung === 0 ? 'checked' : '' %>>
                <label class="btn btn-outline-secondary" for="behinderung-nein">Nein</label>
              </div>
              <!-- Nur bei „Ja" relevant: wer wurde wie behindert. -->
              <div class="mt-2 <%= r.behinderung === 1 ? '' : 'd-none' %>" id="behinderung-detail">
                <label class="form-label">Wer wurde wie behindert?</label>
                <textarea name="behinderung_text" class="form-control" rows="2"
                          placeholder="z.B. Rollstuhlfahrer musste auf die Straße ausweichen"><%= r.behinderung_text || '' %></textarea>
              </div>
            </div>
          </div>

          <div class="d-flex justify-content-between align-items-center">
            <span id="save-status" class="text-muted small"></span>
            <div class="d-flex gap-2">
              <button type="submit" form="discard-form" class="btn btn-outline-danger"
                      onclick="return confirm('Entwurf wirklich verwerfen?')">Verwerfen</button>
              <button type="submit" class="btn btn-primary">Entwurf speichern</button>
            </div>
          </div>
        </form>
      </div>
    </div>

    <p class="text-muted small mt-3">
      * Für den Versand erforderlich. Als Entwurf kannst du jederzeit speichern – auch mit
      nur einem ausgefüllten Feld oder nur einem Foto, etwa um unterwegs Fotos und Standort
      festzuhalten und die Anzeige später zu vervollständigen. Eingaben werden zudem
      automatisch gespeichert. Deine persönlichen Daten (Name, Adresse) werden aus den
      <a href="/settings">Einstellungen</a> übernommen.
    </p>
  </div>
</div>

<form id="discard-form" method="post" action="/report/<%= r.aktenzeichen %>/discard" class="d-none"></form>

<!-- Kurzes Aufleuchten von Feldern, die per KI-Foto-Analyse vorbelegt wurden. -->
<style>
  .ai-filled { animation: ai-flash 2.4s ease-out; }
  @keyframes ai-flash {
    0%   { background-color: #fff3cd; }
    100% { background-color: transparent; }
  }
</style>

<!-- Leaflet für die Tatort-Karte (Tiles kommen same-origin über /tiles/...). -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css">

<!-- Optionale Hilfen: EXIF-GPS und Aufnahmezeit aus Fotos lesen, HEIC im Browser für die Vorschau wandeln. -->
<script src="https://cdn.jsdelivr.net/npm/exifr@7.1.3/dist/lite.umd.js"></script>
<script src="https://cdn.jsdelivr.net/npm/heic2any@0.0.4/dist/heic2any.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/public/js/report-form.js"></script>
<script src="/public/js/report-map.js"></script>
