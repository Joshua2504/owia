<%
const hhmm = (t) => t ? String(t).slice(0, 5) : ''
const tattag = report.tattag
  ? new Date(report.tattag).toLocaleDateString('de-DE', { dateStyle: 'long' })
  : '—'
const von = hhmm(report.tatzeit_von)
const bis = hhmm(report.tatzeit_bis)
const tatzeit = von && bis ? `${von} – ${bis} Uhr` : von ? `${von} Uhr` : bis ? `${bis} Uhr` : '—'
const isVersendet = report.status === 'versendet'
const isEntwurf = report.status === 'entwurf'
const images = locals.images || []
const complete = locals.complete
const versandLabel = {
  gedruckt: 'selbst gedruckt / per Post',
  selbst_email: 'selbst per E-Mail',
  system_email: 'von uns per E-Mail',
}[report.versand_art] || ''
%>

<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="mb-0">Anzeige <code><%= report.aktenzeichen || `#${report.id}` %></code></h2>
      <div class="d-flex gap-2">
        <% if (isEntwurf) { %>
          <a href="/anzeige/<%= report.aktenzeichen %>/bearbeiten" class="btn btn-outline-primary btn-sm">✎ Bearbeiten</a>
        <% } %>
        <a href="/anzeigen" class="btn btn-outline-secondary btn-sm">← Übersicht</a>
      </div>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4">Aktenzeichen</dt>
          <dd class="col-sm-8"><code><%= report.aktenzeichen || '—' %></code></dd>

          <dt class="col-sm-4">Kennzeichen</dt>
          <dd class="col-sm-8"><code><%= report.kennzeichen || '—' %></code></dd>

          <% if (report.fahrzeug_marke) { %>
            <dt class="col-sm-4">Fahrzeug</dt>
            <dd class="col-sm-8"><%= report.fahrzeug_marke %></dd>
          <% } %>

          <dt class="col-sm-4">Tattag</dt>
          <dd class="col-sm-8"><%= tattag %></dd>

          <dt class="col-sm-4">Tatzeit</dt>
          <dd class="col-sm-8"><%= tatzeit %></dd>

          <dt class="col-sm-4">Tatort</dt>
          <dd class="col-sm-8"><%= report.tatort || '—' %></dd>

          <dt class="col-sm-4">Verstoßart</dt>
          <dd class="col-sm-8"><%= report.verstoss_art || '—' %></dd>

          <% if (report.beschreibung) { %>
            <dt class="col-sm-4">Beschreibung</dt>
            <dd class="col-sm-8"><%= report.beschreibung %></dd>
          <% } %>

          <% if (report.behinderung === 1 || report.behinderung === 0) { %>
            <dt class="col-sm-4">Jemand behindert?</dt>
            <dd class="col-sm-8">
              <%= report.behinderung === 1 ? 'Ja' : 'Nein' %>
              <% if (report.behinderung === 1 && report.behinderung_text) { %>
                <span class="text-muted">– <%= report.behinderung_text %></span>
              <% } %>
            </dd>
          <% } %>

          <dt class="col-sm-4">Status</dt>
          <dd class="col-sm-8">
            <% if (isVersendet) { %>
              <span class="badge bg-success">Versendet</span>
              <% if (versandLabel) { %><span class="text-muted small ms-1">(<%= versandLabel %>)</span><% } %>
            <% } else if (isEntwurf) { %>
              <span class="badge bg-secondary">Entwurf</span>
            <% } else { %>
              <span class="badge bg-info">Eingereicht</span>
            <% } %>
          </dd>
        </dl>
      </div>
    </div>

    <% if (images.length > 0) { %>
      <div class="card shadow-sm mb-4">
        <div class="card-header">Beweisfotos (<%= images.length %>)</div>
        <div class="card-body">
          <div class="row g-3">
            <% for (const img of images) { %>
              <div class="col-6 col-md-4">
                <a href="/anzeige/<%= report.aktenzeichen %>/image/<%= img.id %>" target="_blank">
                  <img src="/anzeige/<%= report.aktenzeichen %>/image/<%= img.id %>"
                       class="img-fluid rounded border" alt="Beweisfoto">
                </a>
                <% if (img.original_filename && img.original_filename !== img.filename) { %>
                  <a href="/anzeige/<%= report.aktenzeichen %>/image/<%= img.id %>?original=1"
                     class="d-block small text-muted mt-1">Original herunterladen</a>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>

    <% const replies = locals.replies || [] %>
    <% const attachmentsByReply = locals.attachmentsByReply || {} %>
    <% if (replies.length || isVersendet) { %>
      <div class="card shadow-sm mb-4 border-primary">
        <div class="card-header">📨 Nachrichtenverlauf mit dem Ordnungsamt</div>
        <div class="card-body">
          <% if (!replies.length) { %>
            <p class="text-muted small mb-0">Noch keine Nachrichten gespeichert.</p>
          <% } %>
          <% for (const rep of replies) { %>
            <% const out = rep.direction === 'out' %>
            <div class="mb-3 p-2 rounded <%= out ? 'bg-light border-start border-4 border-secondary' : 'border-start border-4 border-primary' %>">
              <div class="small text-muted mb-1">
                <strong><%= out ? 'Du / OWiA-Anzeiger' : (rep.from_address || 'Ordnungsamt') %></strong>
                <% if (rep.received_at) { %>· <%= new Date(rep.received_at).toLocaleString('de-DE') %><% } %>
                <% if (rep.subject) { %><br><%= rep.subject %><% } %>
              </div>
              <div style="white-space:pre-wrap"><%= rep.body_text || '(kein Text)' %></div>
              <% for (const att of (attachmentsByReply[rep.id] || [])) { %>
                <a class="btn btn-sm btn-outline-secondary mt-2 me-1"
                   href="/anzeige/<%= report.aktenzeichen %>/reply/<%= rep.id %>/attachment/<%= att.id %>">
                  📎 <%= att.original_filename %><% if (att.size_bytes) { %> (<%= Math.round(att.size_bytes / 1024) %> KB)<% } %>
                </a>
              <% } %>
            </div>
          <% } %>

          <% if (isVersendet) { %>
            <!-- Antwort ans Ordnungsamt direkt aus der App (Nutzer in Kopie). -->
            <form method="post" action="/anzeige/<%= report.aktenzeichen %>/message" class="mt-3">
              <label class="form-label small">Nachricht ans Ordnungsamt (z.&nbsp;B. Antwort auf eine Rückfrage)</label>
              <textarea name="text" class="form-control mb-2" rows="4" maxlength="10000" required
                        placeholder="Sehr geehrte Damen und Herren, …"></textarea>
              <button type="submit" class="btn btn-primary btn-sm"
                      onclick="return confirm('Nachricht jetzt ans Ordnungsamt senden?')">
                📤 Senden
              </button>
              <span class="form-text ms-2">Wird von <%= locals.mailFrom || 'unserem Postfach' %> gesendet, du erhältst eine Kopie.</span>
            </form>
          <% } %>
        </div>
      </div>
    <% } %>

    <% if (isEntwurf) { %>
      <% if (report.ablehnung_grund) { %>
        <div class="alert alert-warning">
          <strong>Die Prüfung hat die Anzeige zurückgegeben:</strong>
          <%= report.ablehnung_grund %><br>
          Bitte den Entwurf anpassen und erneut einreichen.
        </div>
      <% } %>
      <% if (!complete) { %>
        <div class="alert alert-warning">
          Es fehlen noch Pflichtangaben. Bitte zuerst
          <a href="/anzeige/<%= report.aktenzeichen %>/bearbeiten" class="alert-link">den Entwurf vervollständigen</a>,
          dann kann die Anzeige eingereicht werden.
        </div>
      <% } %>
      <% if (!locals.profileComplete) { %>
        <div class="alert alert-warning">
          Dein Profil ist unvollständig. Bitte hinterlege
          <a href="/einstellungen" class="alert-link">Name und Anschrift in den Einstellungen</a> –
          anonyme Anzeigen werden vom Ordnungsamt nicht bearbeitet.
        </div>
      <% } %>

      <div class="card shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <h6 class="mb-1">Zur Prüfung einreichen</h6>
            <p class="small text-muted mb-1">
              Die Anzeige wird von uns geprüft und danach inkl. PDF per E-Mail ans
              Ordnungsamt verschickt (du erhältst eine Kopie).
            </p>
            <p class="small text-danger mb-0">
              ⚠️ Wissentlich falsche Anzeigen sind strafbar (falsche Verdächtigung,
              § 164 StGB). Bitte reiche nur wahrheitsgemäße Angaben ein.
            </p>
          </div>
          <form method="post" action="/anzeige/<%= report.aktenzeichen %>/submit"
                onsubmit="return confirm('Anzeige jetzt zur Prüfung einreichen?\n\nMit dem Einreichen bestätigst du die Richtigkeit deiner Angaben – wissentlich falsche Anzeigen sind strafbar (§ 164 StGB).')">
            <button type="submit" class="btn btn-success" <%= complete && locals.profileComplete ? '' : 'disabled' %>>
              ✓ Einreichen
            </button>
          </form>
        </div>
      </div>
    <% } else if (!isVersendet) { %>
      <div class="card shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <h6 class="mb-1">Wird geprüft</h6>
            <p class="small text-muted mb-0">
              Die Anzeige ist eingereicht. Nach der Freigabe verschicken wir sie ans
              Ordnungsamt – du erhältst die E-Mail in Kopie.
            </p>
          </div>
          <form method="post" action="/anzeige/<%= report.aktenzeichen %>/withdraw"
                onsubmit="return confirm('Anzeige zurückziehen und wieder bearbeiten?')">
            <button type="submit" class="btn btn-outline-secondary">Zurückziehen &amp; bearbeiten</button>
          </form>
        </div>
      </div>
    <% } else { %>
      <div class="d-flex gap-2 flex-wrap mb-4">
        <a href="/anzeige/<%= report.aktenzeichen %>/pdf" class="btn btn-outline-primary">⬇ PDF herunterladen</a>
      </div>
    <% } %>

    <!-- PDF-Vorschau ganz unten -->
    <% if (report.pdf_filename) { %>
      <h4 class="mb-3">PDF-Vorschau</h4>
      <iframe src="/anzeige/<%= report.aktenzeichen %>/pdf?inline=1"
              class="w-100 border rounded" style="height: 600px;"
              title="PDF-Vorschau"></iframe>
    <% } else { %>
      <p class="text-muted">Die PDF-Vorschau erscheint, sobald der Entwurf gespeichert wurde.</p>
    <% } %>
  </div>
</div>

