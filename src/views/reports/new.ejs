<%
const v = locals.values || {}
const u = locals.user || {}
%>

<div class="row justify-content-center">
  <div class="col-lg-7">
    <h2 class="mb-4">Neue Anzeige erstatten</h2>

    <% if (locals.error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="card shadow-sm">
      <div class="card-body p-4">
        <form method="post" action="/report" enctype="multipart/form-data">

          <h5 class="mb-3">Fahrzeug</h5>
          <div class="row g-3 mb-4">
            <div class="col-sm-6">
              <label class="form-label">Kennzeichen <span class="text-danger">*</span></label>
              <input type="text" name="kennzeichen" class="form-control text-uppercase"
                     value="<%= v.kennzeichen || '' %>" required
                     placeholder="z.B. F-AB 1234">
            </div>
            <div class="col-sm-6">
              <label class="form-label">Fahrzeugmarke / -farbe</label>
              <input type="text" name="fahrzeug_marke" class="form-control"
                     value="<%= v.fahrzeug_marke || '' %>"
                     placeholder="z.B. VW Golf, grau">
            </div>
          </div>

          <h5 class="mb-3">Tat</h5>
          <div class="row g-3 mb-4">
            <div class="col-sm-4">
              <label class="form-label">Tattag <span class="text-danger">*</span></label>
              <input type="date" name="tattag" class="form-control"
                     value="<%= v.tattag || '' %>" required>
            </div>
            <div class="col-sm-4">
              <label class="form-label">Uhrzeit von <span class="text-danger">*</span></label>
              <input type="time" name="tatzeit_von" class="form-control"
                     value="<%= v.tatzeit_von || '' %>" required>
            </div>
            <div class="col-sm-4">
              <label class="form-label">Uhrzeit bis</label>
              <input type="time" name="tatzeit_bis" class="form-control"
                     value="<%= v.tatzeit_bis || '' %>">
            </div>
            <div class="col-sm-12">
              <label class="form-label">Tatort <span class="text-danger">*</span></label>
              <input type="text" name="tatort" id="tatort" class="form-control"
                     value="<%= v.tatort || '' %>" required
                     data-address-autocomplete data-fill="full" data-geo-scope="ffm"
                     placeholder="Adresse in Frankfurt eingeben und aus der Liste wählen …">
              <div class="d-flex align-items-center flex-wrap gap-2 mt-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-current-location">
                  📍 Aktuellen Standort verwenden
                </button>
                <span id="geo-status" class="form-text m-0"></span>
              </div>
              <div class="form-text">
                Adresse tippen und einen Vorschlag wählen, den aktuellen Standort verwenden
                oder unten den Standort aus einem Foto übernehmen.
              </div>
            </div>
            <div class="col-sm-12">
              <label class="form-label">Verstoßart <span class="text-danger">*</span></label>
              <select name="verstoss_art" class="form-select" required>
                <option value="">– bitte wählen –</option>
                <% for (const art of verstossArten) { %>
                  <option value="<%= art %>" <%= v.verstoss_art === art ? 'selected' : '' %>><%= art %></option>
                <% } %>
              </select>
            </div>
            <div class="col-sm-12">
              <label class="form-label">Beschreibung</label>
              <textarea name="beschreibung" class="form-control" rows="3"
                        placeholder="Optionale Schilderung des Vorfalls"><%= v.beschreibung || '' %></textarea>
            </div>
          </div>

          <h5 class="mb-3">Beweisfotos</h5>
          <div class="mb-4">
            <label class="form-label">Bilder hochladen</label>
            <input type="file" name="bilder" id="bilder-input" class="form-control"
                   accept="image/png,image/jpeg,image/heic,image/heif,.heic,.heif" multiple>
            <div class="form-text">
              JPG, PNG oder HEIC, bis 20 MB pro Bild (max. 10 Bilder). HEIC-Fotos werden
              automatisch in JPG umgewandelt, das Original bleibt erhalten. Die Bilder
              werden an das PDF angehängt und in Ihrem Konto gespeichert.
            </div>
            <div class="form-text">
              In der Vorschau können Sie Bereiche (z.&nbsp;B. Personen) schwärzen. Geschwärzte
              Bilder werden bereits im Browser unkenntlich gemacht – nur diese geschwärzte
              Fassung wird hochgeladen.
            </div>
            <div id="image-editor" class="row g-3 mt-1"></div>
          </div>

          <div class="d-flex justify-content-between">
            <a href="/dashboard" class="btn btn-outline-secondary">Abbrechen</a>
            <button type="submit" class="btn btn-primary">Anzeige einreichen</button>
          </div>
        </form>
      </div>
    </div>

    <p class="text-muted small mt-3">
      * Pflichtfelder. Ihre persönlichen Daten (Name, Adresse) werden aus den
      <a href="/settings">Einstellungen</a> übernommen und im PDF-Formular eingetragen.
    </p>
  </div>
</div>

<!-- Optionale Hilfen: EXIF-GPS aus Fotos lesen, HEIC im Browser für die Vorschau wandeln. -->
<script src="https://cdn.jsdelivr.net/npm/exifr@7.1.3/dist/lite.umd.js"></script>
<script src="https://cdn.jsdelivr.net/npm/heic2any@0.0.4/dist/heic2any.min.js"></script>
<script src="/public/js/report-form.js"></script>
