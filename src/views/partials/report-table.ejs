<%
// Gemeinsame Anzeigen-Tabelle für Dashboard und Foto-Import-Übersicht.
// Alle Details stehen in der Tabelle (Zeile: report-row.ejs); bearbeitet wird
// ausschließlich auf der Anzeigen-Seite (Link "Bearbeiten" bei Entwürfen).
// Erwartet: reports (Felder s. report-row.ejs inkl. status), imagesByReport
// ({ reportId: [imageIds] }), optional queueId (Edit-Links öffnen die
// Review-Queue des Batches).
// Thumbnails: Klick = Lightbox, Ziehen = in anderen Entwurf verschieben
// (public/js/report-table.js muss auf der Seite eingebunden sein).
const _queueId = typeof queueId !== 'undefined' && queueId ? queueId : null
const _hasDrafts = reports.some((r) => r.status === 'entwurf')
%>
<div class="table-responsive">
  <table class="table table-sm table-hover align-middle mb-0">
    <thead class="table-light">
      <tr>
        <th>Fotos</th>
        <th>Aktenzeichen</th>
        <th>Kennzeichen</th>
        <th>Tattag / Zeit</th>
        <th>Tatort</th>
        <th>Verstoß</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% for (const r of reports) { %>
        <%- include('report-row', {
          r,
          imgIds: (typeof imagesByReport !== 'undefined' && imagesByReport && imagesByReport[r.id]) || [],
          queueId: _queueId,
        }) %>
      <% } %>
    </tbody>
  </table>
</div>
<% if (_hasDrafts) { %>
  <!-- Drop-Ziel: Foto hierher ziehen, um dafür eine neue Anzeige anzulegen.
       (report-table.js zieht es beim Drag-Start als Zwischenzeile direkt unter
       den Quell-Eintrag; data-queue reicht die Review-Queue an neue Zeilen weiter.) -->
  <div id="drop-new-draft" data-queue="<%= _queueId || '' %>"
       class="border border-2 border-dashed rounded text-center text-muted py-2 mt-2 mx-3 mb-3 small">
    ➕ Foto hierher ziehen, um eine <strong>neue Anzeige</strong> daraus zu erstellen
  </div>
<% } %>
