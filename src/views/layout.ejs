<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> – OWiA-Anzeiger</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/public/css/app.css">
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/dashboard">🚗 OWiA-Anzeiger</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="nav">
        <ul class="navbar-nav ms-auto align-items-center gap-2">
          <% if (currentUser) { %>
            <li class="nav-item">
              <form method="post" action="/report/new" class="m-0">
                <button type="submit" class="btn btn-link nav-link p-0">+ Neue Anzeige</button>
              </form>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/settings"><%= currentUser.name %></a>
            </li>
            <li class="nav-item">
              <a class="btn btn-outline-light btn-sm" href="/logout">Abmelden</a>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="btn btn-primary btn-sm" href="/login">Anmelden</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <% if (flash) { %>
      <div class="alert alert-<%= flash.type === 'success' ? 'success' : 'danger' %> alert-dismissible fade show" role="alert">
        <%= flash.message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <%- body %>
  </main>

  <footer class="text-center text-muted py-4 small">
    <div>Dieses Tool ist kein offizielles Angebot der Stadt Frankfurt.</div>
    <div class="mt-1">
      <a href="/impressum" class="text-muted">Impressum</a> ·
      <a href="/datenschutz" class="text-muted">Datenschutz</a> ·
      <a href="/nutzungsbedingungen" class="text-muted">Nutzungsbedingungen</a>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/public/js/address-autocomplete.js"></script>
</body>
</html>
