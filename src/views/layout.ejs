<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script>
    // Theme VOR dem ersten Rendern setzen (kein Aufblitzen): gespeicherte Wahl,
    // sonst Systemeinstellung. Umschalter unten in der Navbar.
    (function () {
      var theme
      try { theme = localStorage.getItem('theme') } catch (_) {}
      if (theme !== 'light' && theme !== 'dark') {
        theme = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
      }
      document.documentElement.setAttribute('data-bs-theme', theme)
    })()
  </script>
  <title><%= locals.pageTitle || `${title} – OWiA-Anzeiger` %></title>
  <%# SEO: Beschreibung/Canonical/OG setzen nur öffentliche Seiten (z.B. Startseite);
      interne Seiten bleiben ohne (und sind per robots.txt ausgenommen). %>
  <% if (locals.metaDescription) { %>
    <meta name="description" content="<%= metaDescription %>">
    <meta property="og:title" content="<%= locals.pageTitle || title %>">
    <meta property="og:description" content="<%= metaDescription %>">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="de_DE">
    <meta property="og:site_name" content="OWiA-Anzeiger">
    <% if (locals.canonical) { %>
      <meta property="og:url" content="<%= canonical %>">
      <link rel="canonical" href="<%= canonical %>">
    <% } %>
    <meta name="twitter:card" content="summary">
  <% } %>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🚗</text></svg>">
  <link rel="stylesheet" href="/public/vendor/bootstrap.min.css">
  <link rel="stylesheet" href="/public/css/app.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/">🚗 OWiA-Anzeiger</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="nav">
        <ul class="navbar-nav ms-auto align-items-center gap-2">
          <% if (currentUser) { %>
            <li class="nav-item">
              <form method="post" action="/anzeige/neu" class="m-0">
                <button type="submit" class="btn btn-link nav-link p-0">+ Neue Anzeige</button>
              </form>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/anzeigen">Meine Anzeigen</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/import">📸 Foto-Import</a>
            </li>
            <% if (isAdmin) { %>
              <li class="nav-item">
                <a class="nav-link" href="/admin/anzeigen">Prüfung</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/admin/newsletter">Newsletter</a>
              </li>
            <% } %>
            <li class="nav-item">
              <a class="nav-link" href="/einstellungen"><%= currentUser.name %></a>
            </li>
            <li class="nav-item">
              <a class="btn btn-outline-light btn-sm" href="/logout">Abmelden</a>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="btn btn-primary btn-sm" href="/login">Anmelden</a></li>
          <% } %>
          <li class="nav-item">
            <button type="button" id="theme-toggle" class="btn btn-link nav-link p-0"
                    title="Hell/Dunkel umschalten" aria-label="Farbschema umschalten">🌙</button>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <% if (flash) { %>
      <div id="flash-message" class="alert alert-<%= flash.type === 'success' ? 'success' : 'danger' %> alert-dismissible fade show" role="alert">
        <%= flash.message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Schließen"></button>
      </div>
      <script>
        (function () {
          var el = document.getElementById('flash-message')
          if (!el) return
          function dismiss() {
            el.classList.remove('show')
            setTimeout(function () { el.remove() }, 200)
          }
          // Eigener Handler, damit das X auch ohne geladenes Bootstrap-JS funktioniert.
          var closeBtn = el.querySelector('.btn-close')
          if (closeBtn) closeBtn.addEventListener('click', dismiss)
          // Erfolgsmeldungen nach kurzer Zeit automatisch ausblenden.
          if (el.classList.contains('alert-success')) setTimeout(dismiss, 6000)
        })()
      </script>
    <% } %>

    <%- body %>
  </main>

  <!-- Cookie-Hinweis: rein informativ, da ausschließlich technisch notwendige
       Cookies (Sitzung + Statusmeldung) genutzt werden – keine Einwilligung
       erforderlich (§ 25 Abs. 2 TTDSG). Bestätigung merkt sich localStorage. -->
  <div id="cookie-notice" class="d-none position-fixed bottom-0 start-0 end-0 p-2" style="z-index:2100">
    <div class="container">
      <div class="bg-dark text-white rounded shadow p-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
        <span class="small">
          🍪 Diese Website verwendet ausschließlich <strong>technisch notwendige</strong> Cookies
          (Anmeldung &amp; Statusmeldungen) – kein Tracking, keine Werbung.
          <a href="/datenschutz" class="link-light">Mehr in der Datenschutzerklärung</a>.
        </span>
        <button type="button" id="cookie-notice-ok" class="btn btn-light btn-sm">Verstanden</button>
      </div>
    </div>
  </div>
  <script>
    (function () {
      try {
        if (localStorage.getItem('cookieNoticeSeen')) return
      } catch (_) { /* localStorage gesperrt -> Hinweis einfach zeigen */ }
      var box = document.getElementById('cookie-notice')
      var ok = document.getElementById('cookie-notice-ok')
      if (!box || !ok) return
      box.classList.remove('d-none')
      ok.addEventListener('click', function () {
        try { localStorage.setItem('cookieNoticeSeen', '1') } catch (_) {}
        box.remove()
      })
    })()
  </script>

  <footer class="text-center text-muted py-4 small">
    <div class="mt-1">
      <a href="/impressum" class="text-muted">Impressum</a> ·
      <a href="/datenschutz" class="text-muted">Datenschutz</a> ·
      <a href="/nutzungsbedingungen" class="text-muted">Nutzungsbedingungen</a>
    </div>
  </footer>

  <script>
    // Hell/Dunkel-Umschalter: Wahl in localStorage, Icon zeigt das Ziel-Theme.
    (function () {
      var btn = document.getElementById('theme-toggle')
      if (!btn) return
      function icon() {
        btn.textContent = document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '☀️' : '🌙'
      }
      icon()
      btn.addEventListener('click', function () {
        var next = document.documentElement.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark'
        document.documentElement.setAttribute('data-bs-theme', next)
        try { localStorage.setItem('theme', next) } catch (_) {}
        icon()
      })
    })()
  </script>
  <script src="/public/vendor/bootstrap.bundle.min.js"></script>
  <script src="/public/js/address-autocomplete.js"></script>
</body>
</html>
