<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="mb-0">Guthaben-Konto</h2>
      <a href="/dashboard" class="btn btn-outline-secondary btn-sm">← Übersicht</a>
    </div>

    <div class="alert alert-light border small" role="note">
      <strong>Warum kostet die KI-Analyse etwas?</strong>
      Dieses Tool ist ein Hobby-Projekt. Die KI-Bildanalyse (Kennzeichen- und
      Verstoßerkennung) läuft auf eigenen Servern und verursacht laufende Rechenkosten.
      Mit deinem Guthaben decken wir <strong>ausschließlich diese Server-Kosten</strong> –
      wir verdienen daran nichts. Alles andere (Datum, Uhrzeit, Adresse, Versand der
      Anzeige) bleibt kostenlos.
    </div>

    <!-- Guthaben -->
    <div class="card shadow-sm mb-4">
      <div class="card-body p-4">
        <div class="row text-center g-3">
          <div class="col">
            <div class="text-muted small">Verfügbar gesamt</div>
            <div class="fs-3 fw-bold"><%= fmt(balance.totalCents) %></div>
          </div>
          <div class="col">
            <div class="text-muted small">Bezahltes Guthaben</div>
            <div class="fs-4"><%= fmt(balance.balanceCents) %></div>
          </div>
          <div class="col">
            <div class="text-muted small">Gratis (heute)</div>
            <div class="fs-4"><%= fmt(balance.freeCents) %></div>
          </div>
        </div>
        <p class="text-muted small mt-3 mb-0">
          Jede KI-Foto-Analyse kostet 0,10 €. Du hast täglich 0,20 € frei (Übertrag bis
          max. 0,40 €). Datum, Uhrzeit und Adresse sind kostenlos.
        </p>
      </div>
    </div>

    <!-- Analyse-Flatrate -->
    <div class="card shadow-sm mb-4">
      <div class="card-header">Analyse-Flatrate</div>
      <div class="card-body p-4">
        <% if (subscription.active) { %>
          <p class="mb-2">
            <span class="badge bg-success">aktiv</span>
            Unbegrenzte KI-Analysen bis
            <strong><%= subscription.activeUntil ? new Date(subscription.activeUntil).toLocaleDateString('de-DE') : '' %></strong>.
          </p>
          <form method="post" action="/konto/abo">
            <button type="submit" class="btn btn-outline-primary btn-sm">
              Um <%= subscriptionDays %> Tage verlängern (<%= fmt(subscriptionCents) %>)
            </button>
          </form>
        <% } else { %>
          <p class="mb-2">
            Für <strong><%= fmt(subscriptionCents) %></strong> pro <%= subscriptionDays %> Tage
            unbegrenzt viele Bilder analysieren.
          </p>
          <form method="post" action="/konto/abo"
                onsubmit="return confirm('Flatrate für <%= fmt(subscriptionCents) %> buchen?')">
            <button type="submit" class="btn btn-primary" <%= balance.balanceCents < subscriptionCents ? 'disabled' : '' %>>
              Flatrate buchen (<%= fmt(subscriptionCents) %>)
            </button>
            <% if (balance.balanceCents < subscriptionCents) { %>
              <span class="form-text ms-2">Bitte zuerst genug bezahltes Guthaben aufladen.</span>
            <% } %>
          </form>
        <% } %>
      </div>
    </div>

    <!-- Aufladen -->
    <div class="card shadow-sm mb-4">
      <div class="card-header">Guthaben aufladen</div>
      <div class="card-body p-4">
        <form method="post" action="/konto/einzahlung" class="row g-3 align-items-end">
          <div class="col-sm-4">
            <label class="form-label">Betrag (€)</label>
            <input type="number" name="amount" class="form-control" step="0.01"
                   min="<%= (minTopup / 100).toFixed(2) %>" value="<%= (minTopup / 100).toFixed(2) %>">
          </div>
          <div class="col-sm-5">
            <label class="form-label">Zahlungsart</label>
            <select name="method" class="form-select">
              <option value="ueberweisung">Überweisung</option>
              <option value="paypal">PayPal</option>
            </select>
          </div>
          <div class="col-sm-3">
            <button type="submit" class="btn btn-primary w-100">Weiter</button>
          </div>
        </form>
        <div class="form-text mt-2">
          Mindestbetrag: <%= fmt(minTopup) %>. Die Gutschrift erfolgt nach manueller Prüfung;
          anschließend erhältst du eine Rechnung per E-Mail.
        </div>
      </div>
    </div>

    <!-- Einzahlungen -->
    <% if (deposits.length) { %>
      <div class="card shadow-sm mb-4">
        <div class="card-header">Einzahlungen</div>
        <div class="list-group list-group-flush">
          <% for (const d of deposits) { %>
            <div class="list-group-item d-flex justify-content-between align-items-center">
              <div>
                <strong><%= fmt(d.amount_cents) %></strong> · <%= methodLabel(d.method) %>
                <div class="small text-muted">
                  Verwendungszweck: <%= d.reference %><%= d.invoice_number ? ' · Rechnung ' + d.invoice_number : '' %>
                </div>
              </div>
              <div class="text-end">
                <% if (d.status === 'pending') { %>
                  <a href="/konto/einzahlung/<%= d.id %>" class="badge bg-warning text-dark text-decoration-none">offen – Zahlungsdaten</a>
                <% } else if (d.status === 'confirmed') { %>
                  <span class="badge bg-success">gutgeschrieben</span>
                <% } else { %>
                  <span class="badge bg-secondary">storniert</span>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    <% } %>

    <!-- Jobs / Erstattung -->
    <% if (jobs.length) { %>
      <div class="card shadow-sm mb-4">
        <div class="card-header">Analysen (Jobs)</div>
        <div class="list-group list-group-flush">
          <% for (const j of jobs) { %>
            <div class="list-group-item d-flex justify-content-between align-items-center">
              <div>
                <strong><%= fmt(jobCostCents(j)) %></strong> · KI-Foto-Analyse
                <div class="small text-muted"><%= new Date(j.created_at).toLocaleString('de-DE') %></div>
              </div>
              <div class="text-end">
                <% if (j.request_status === 'pending') { %>
                  <span class="badge bg-info text-dark">Erstattung beantragt</span>
                <% } else if (j.request_status === 'approved' || Number(j.refund_count) > 0) { %>
                  <span class="badge bg-success">erstattet</span>
                <% } else if (j.request_status === 'rejected') { %>
                  <span class="badge bg-secondary">Antrag abgelehnt</span>
                <% } else { %>
                  <a href="/konto/erstattung/<%= j.id %>" class="btn btn-outline-secondary btn-sm">Erstattung beantragen</a>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    <% } %>

    <!-- Buchungen -->
    <% if (ledger.length) { %>
      <% const typeLabel = (t) => ({ topup: 'Aufladung', analysis_charge: 'Analyse', refund: 'Erstattung', adjustment: 'Korrektur', subscription: 'Flatrate' })[t] || t %>
      <div class="card shadow-sm mb-4">
        <div class="card-header">Buchungen</div>
        <div class="table-responsive">
          <table class="table table-sm mb-0 align-middle">
            <thead><tr><th>Datum</th><th>Art</th><th class="text-end">Betrag</th></tr></thead>
            <tbody>
              <% for (const t of ledger) { %>
                <% const paid = Number(t.amount_cents); const free = Number(t.free_used_cents); %>
                <tr>
                  <td class="small"><%= new Date(t.created_at).toLocaleString('de-DE') %></td>
                  <td>
                    <%= typeLabel(t.type) %>
                    <% if (t.description) { %><div class="small text-muted"><%= t.description %></div><% } %>
                  </td>
                  <td class="text-end">
                    <%= paid !== 0 ? fmt(paid) : '—' %>
                    <% if (free) { %>
                      <div class="small text-muted"><%= free > 0 ? '−' : '+' %><%= fmt(Math.abs(free)) %> gratis</div>
                    <% } %>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>
</div>
