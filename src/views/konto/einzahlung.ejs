<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="mb-0">Aufladung</h2>
      <a href="/konto" class="btn btn-outline-secondary btn-sm">← Konto</a>
    </div>

    <div class="card shadow-sm">
      <div class="card-body p-4">
        <% if (order.status === 'confirmed') { %>
          <div class="alert alert-success mb-0">
            Diese Einzahlung wurde bereits gutgeschrieben<%= order.invoice_number ? ' (Rechnung ' + order.invoice_number + ')' : '' %>.
          </div>
        <% } else if (order.status === 'cancelled') { %>
          <div class="alert alert-secondary mb-0">Dieser Einzahlungsauftrag wurde storniert.</div>
        <% } else { %>
          <p>
            Bitte überweise <strong><%= fmt(order.amount_cents) %></strong> mit dem unten genannten
            <strong>Verwendungszweck</strong>. Nach Zahlungseingang schreiben wir das Guthaben
            manuell gut und schicken dir eine Rechnung per E-Mail.
          </p>

          <% if (order.method === 'paypal') { %>
            <table class="table">
              <tr><th style="width:40%">PayPal-Empfänger</th><td><%= paypal %></td></tr>
              <tr><th>Betrag</th><td><%= fmt(order.amount_cents) %></td></tr>
              <tr><th>Verwendungszweck</th><td><code><%= order.reference %></code></td></tr>
            </table>
            <div class="form-text">
              Bitte als „Freunde &amp; Familie" senden und den Verwendungszweck angeben, damit wir
              die Zahlung zuordnen können.
            </div>
          <% } else { %>
            <table class="table">
              <tr><th style="width:40%">Kontoinhaber</th><td><%= bank.holder || '—' %></td></tr>
              <tr><th>IBAN</th><td><%= bank.iban || '—' %></td></tr>
              <tr><th>BIC</th><td><%= bank.bic || '—' %></td></tr>
              <tr><th>Bank</th><td><%= bank.name || '—' %></td></tr>
              <tr><th>Betrag</th><td><%= fmt(order.amount_cents) %></td></tr>
              <tr><th>Verwendungszweck</th><td><code><%= order.reference %></code></td></tr>
            </table>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>
</div>
